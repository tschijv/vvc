generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Referentiemodel ────────────────────────────────────────────────────────

model Referentiecomponent {
  id                    String                       @id @default(uuid())
  naam                  String
  guid                  String?
  beschrijving          String?
  status                String?
  pakketten             PakketReferentiecomponent[]
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
}

model Standaard {
  id                    String            @id @default(uuid())
  naam                  String
  guid                  String?
  beschrijving          String?
  versies               Standaardversie[]
  testrapporten         Testrapport[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Standaardversie {
  id                    String                  @id @default(uuid())
  naam                  String
  guid                  String?
  status                String?
  compliancyMonitor     Boolean                 @default(false)
  standaard             Standaard               @relation(fields: [standaardId], references: [id])
  standaardId           String
  pakketten             PakketStandaard[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}

model Applicatiefunctie {
  id                    String                     @id @default(uuid())
  naam                  String                     @unique
  guid                  String?
  beschrijving          String?
  pakketten             PakketApplicatiefunctie[]
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
}

// ─── GEMMA Views ───────────────────────────────────────────────────────────

model GemmaView {
  id        String   @id @default(uuid())
  objectId  String   @unique
  titel     String
  domein    String   @default("")
  laag      String   @default("")
  modelId   String
  volgorde  Int      @default(0)
  actief    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Gebruikers & Autorisatie ────────────────────────────────────────────────

enum Role {
  GEVERIFIEERD
  GEMEENTE_RAADPLEGER
  GEMEENTE_BEHEERDER
  SAMENWERKING_BEHEERDER
  LEVERANCIER
  REDACTEUR
  KING_RAADPLEGER
  KING_BEHEERDER
  ADMIN
  API_USER
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  naam          String
  passwordHash  String?
  actief        Boolean      @default(true)
  rollen        Role[]       @default([GEVERIFIEERD])
  organisatieId String?      @map("gemeenteId")
  organisatie   Organisatie? @relation(fields: [organisatieId], references: [id])
  leverancierId String?
  leverancier   Leverancier? @relation(fields: [leverancierId], references: [id])
  laatsteToegangOp DateTime?
  registratieBron  String       @default("admin")
  organisatieType  String?
  organisatieNaam  String?
  afgewezen        Boolean      @default(false)
  telefoon         String?
  functie          String?
  lastLoginAt      DateTime?
  emailNotificaties Boolean     @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  passwordResetTokens PasswordResetToken[]
  notificaties        Notificatie[]
  favorieten          Favoriet[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─── Leveranciers ───────────────────────────────────────────────────────────

model Leverancier {
  id                    String                @id @default(uuid())
  naam                  String
  slug                  String                @unique
  logo                  String?
  contactpersoon        String?
  email                 String?
  telefoon              String?
  website               String?
  heeftGeldigConvenant  Boolean               @default(false)
  beschrijvingDiensten  String?
  supportPortalUrl      String?
  documentatieUrl       String?
  kennisbankUrl         String?
  aanmaakdatum          DateTime?
  lastActivity          DateTime?
  pakketten             Pakket[]
  addenda               LeverancierAddendum[]
  users                 User[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model Addendum {
  id                    String                @id @default(uuid())
  naam                  String                @unique
  beschrijving          String?
  url                   String?
  leveranciers          LeverancierAddendum[]
  createdAt             DateTime              @default(now())
}

model LeverancierAddendum {
  leverancier           Leverancier @relation(fields: [leverancierId], references: [id])
  leverancierId         String
  addendum              Addendum    @relation(fields: [addendumId], references: [id])
  addendumId            String
  ondertekend           DateTime?   // signing date
  deadline              DateTime?   // implementation deadline

  @@id([leverancierId, addendumId])
  @@index([leverancierId])
  @@index([addendumId])
}

// ─── Pakketten ───────────────────────────────────────────────────────────────

model Pakket {
  id                    String                       @id @default(uuid())
  naam                  String
  slug                  String                       @unique
  beschrijving          String?
  urlProductpagina      String?
  aantalGemeenten       Int                          @default(0)
  mutatiedatum          DateTime?
  leverancier           Leverancier                  @relation(fields: [leverancierId], references: [id])
  leverancierId         String
  versies               Pakketversie[]
  contactpersonen       PakketContact[]
  referentiecomponenten PakketReferentiecomponent[]
  standaarden           PakketStandaard[]
  applicatiefuncties    PakketApplicatiefunctie[]
  technologieen         PakketTechnologie[]
  dienstverleners       DienstverlenerPakket[]
  cloudproviders        CloudproviderPakket[]
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@index([leverancierId])
}

model PakketContact {
  id            String  @id @default(uuid())
  naam          String
  email         String?
  telefoon      String?
  rol           String?
  pakket        Pakket  @relation(fields: [pakketId], references: [id], onDelete: Cascade)
  pakketId      String
  createdAt     DateTime @default(now())
}

model Pakketversie {
  id                    String         @id @default(uuid())
  naam                  String
  status                String
  beschrijving          String?
  startOntwikkeling     DateTime?
  startTest             DateTime?
  startDistributie      DateTime?
  aantalGemeenten       Int            @default(0)
  mutatiedatum          DateTime?
  pakket                Pakket         @relation(fields: [pakketId], references: [id])
  pakketId              String
  organisatiePakketten  OrganisatiePakket[]
  koppelingenAlsBron    Koppeling[]    @relation("koppelingBron")
  koppelingenAlsDoel    Koppeling[]    @relation("koppelingDoel")
  koppelingenAlsIntermediair Koppeling[] @relation("koppelingIntermediair")
  testrapporten         Testrapport[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([pakketId])
}

// ─── Testrapporten ──────────────────────────────────────────────────────────

model Testrapport {
  id              String        @id @default(uuid())
  pakketversie    Pakketversie  @relation(fields: [pakketversieId], references: [id])
  pakketversieId  String
  standaard       Standaard     @relation(fields: [standaardId], references: [id])
  standaardId     String
  status          String        @default("Onbekend") // Voldoet, Voldoet niet, Onbekend
  rapportUrl      String?
  datumTest       DateTime?
  createdAt       DateTime      @default(now())

  @@unique([pakketversieId, standaardId])
  @@index([pakketversieId])
  @@index([standaardId])
}

// ─── Koppeltabellen ──────────────────────────────────────────────────────────

model PakketReferentiecomponent {
  pakket                Pakket              @relation(fields: [pakketId], references: [id])
  pakketId              String
  referentiecomponent   Referentiecomponent @relation(fields: [referentiecomponentId], references: [id])
  referentiecomponentId String
  type                  String              // leverancier | gemeente
  aantalGemeenten       Int                 @default(0)

  @@id([pakketId, referentiecomponentId, type])
  @@index([referentiecomponentId])
}

model PakketStandaard {
  pakket                Pakket          @relation(fields: [pakketId], references: [id])
  pakketId              String
  standaardversie       Standaardversie @relation(fields: [standaardversieId], references: [id])
  standaardversieId     String
  compliancy            Boolean?
  testrappportUrl       String?
  compliancyIndicated   Boolean?

  @@id([pakketId, standaardversieId])
  @@index([standaardversieId])
  @@index([compliancy])
}

model PakketApplicatiefunctie {
  pakket                Pakket            @relation(fields: [pakketId], references: [id])
  pakketId              String
  applicatiefunctie     Applicatiefunctie @relation(fields: [applicatiefunctieId], references: [id])
  applicatiefunctieId   String
  ondersteund           Boolean           @default(true)

  @@id([pakketId, applicatiefunctieId])
}

model PakketTechnologie {
  pakket                Pakket @relation(fields: [pakketId], references: [id])
  pakketId              String
  technologie           String

  @@id([pakketId, technologie])
}

// ─── Organisaties (voorheen Gemeenten) ──────────────────────────────────────

model Organisatie {
  id                    String                    @id @default(uuid())
  naam                  String
  cbsCode               String?
  contactpersoon        String?
  email                 String?
  telefoon              String?
  website               String?
  progress              Int                       @default(0)
  lastActivity          DateTime?
  pakketten             OrganisatiePakket[]
  samenwerkingen        SamenwerkingOrganisatie[]
  koppelingen           Koppeling[]
  users                 User[]
  dienstverleners       DienstverlenerOrganisatie[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@map("Gemeente")
}

model OrganisatiePakket {
  organisatie           Organisatie  @relation(fields: [organisatieId], references: [id])
  organisatieId         String       @map("gemeenteId")
  pakketversie          Pakketversie @relation(fields: [pakketversieId], references: [id])
  pakketversieId        String
  status                String?
  datumIngangStatus     DateTime?
  technologie           String?
  mutatiedatum          DateTime?
  verantwoordelijke     String?
  licentievorm          String?
  aantalGebruikers      Int?
  maatwerk              String?

  @@id([organisatieId, pakketversieId])
  @@index([organisatieId])
  @@index([pakketversieId])
  @@map("GemeentePakket")
}

// ─── Samenwerkingen ──────────────────────────────────────────────────────────

model Samenwerking {
  id                    String                 @id @default(uuid())
  naam                  String
  type                  String?
  contactpersoon        String?
  email                 String?
  organisaties          SamenwerkingOrganisatie[]
  createdAt             DateTime               @default(now())
}

model SamenwerkingOrganisatie {
  samenwerking          Samenwerking @relation(fields: [samenwerkingId], references: [id])
  samenwerkingId        String
  organisatie           Organisatie  @relation(fields: [organisatieId], references: [id])
  organisatieId         String       @map("gemeenteId")

  @@id([samenwerkingId, organisatieId])
  @@map("SamenwerkingGemeente")
}

// ─── Koppelingen ─────────────────────────────────────────────────────────────

model Koppeling {
  id                        String        @id @default(uuid())
  organisatie               Organisatie   @relation(fields: [organisatieId], references: [id])
  organisatieId             String        @map("gemeenteId")
  bronPakketversie          Pakketversie? @relation("koppelingBron", fields: [bronPakketversieId], references: [id])
  bronPakketversieId        String?
  bronExternPakket          ExternPakket? @relation("koppelingBronExtern", fields: [bronExternPakketId], references: [id])
  bronExternPakketId        String?
  richting                  String        @default("beide") // "heen" (→), "weer" (←), "beide" (↔)
  doelPakketversie          Pakketversie? @relation("koppelingDoel", fields: [doelPakketversieId], references: [id])
  doelPakketversieId        String?
  doelExternPakket          ExternPakket? @relation("koppelingDoelExtern", fields: [doelExternPakketId], references: [id])
  doelExternPakketId        String?
  buitengemeentelijk        Boolean       @default(false)
  status                    String?
  standaard                 String?
  datumIngangStatus         DateTime?
  transportprotocol         String?
  aanvullendeInformatie     String?
  intermediairPakketversie  Pakketversie? @relation("koppelingIntermediair", fields: [intermediairPakketversieId], references: [id])
  intermediairPakketversieId String?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  @@index([organisatieId])
  @@index([status])
}

// ─── CMS Pagina's ──────────────────────────────────────────────────────────

model Pagina {
  id        String   @id @default(uuid())
  slug      String   @unique
  titel     String
  inhoud    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Begrippen (NL-SBB / SKOSMOS) ───────────────────────────────────────────

model Begrip {
  id            String   @id @default(uuid())
  term          String                   // skos:prefLabel
  definitie     String                  // skos:definition
  toelichting   String?                 // rdfs:comment
  scopeNote     String?                 // skos:scopeNote
  bron          String?                 // Bronverwijzing
  uri           String   @unique        // NL-SBB concept URI
  synoniemen    String[] @default([])   // skos:altLabel
  vocab         String   @default("")   // SKOSMOS vocabulary ID
  status        String   @default("actief")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([term, vocab])
}

// ─── Notificaties ────────────────────────────────────────────────────────────

model Notificatie {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  titel       String
  bericht     String
  type        String    @default("info") // info, warning, error, success
  gelezen     Boolean   @default(false)
  link        String?   // optional link to navigate to
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([userId, gelezen])
  @@index([createdAt])
}

// ─── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  userEmail String?
  actie     String   // login, create, update, delete, sync, merge, etc.
  entiteit  String   // User, Gemeente, Pakket, etc.
  entiteitId String?
  details   String?
  ipAdres   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([entiteit])
  @@index([entiteitId])
}

// ─── Extern Pakket ───────────────────────────────────────────────────────────

model ExternPakket {
  id                    String        @id @default(uuid())
  naam                  String
  leverancierNaam       String?
  versie                String?
  beschrijving          String?
  koppelingenAlsBron    Koppeling[]   @relation("koppelingBronExtern")
  koppelingenAlsDoel    Koppeling[]   @relation("koppelingDoelExtern")
  createdAt             DateTime      @default(now())
}

// ─── Applicatie-instellingen (key-value) ─────────────────────────────────────

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Favorieten ─────────────────────────────────────────────────────────────

model Favoriet {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType  String   // "pakket" | "gemeente" | "leverancier"
  entityId    String
  createdAt   DateTime @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId])
}

// ─── Dienstverleners ─────────────────────────────────────────────────────────

model Dienstverlener {
  id              String   @id @default(cuid())
  naam            String
  slug            String   @unique
  beschrijving    String?
  type            String   @default("Advies") // Implementatie, Beheer, Advies, Hosting, Training
  specialisaties  String?  // Comma-separated
  contactpersoon  String?
  email           String?
  telefoon        String?
  website         String?
  regio           String?  // Landelijk, Regionaal, Lokaal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pakketten       DienstverlenerPakket[]
  organisaties    DienstverlenerOrganisatie[]
}

model DienstverlenerPakket {
  dienstverlener   Dienstverlener @relation(fields: [dienstverlenerId], references: [id])
  dienstverlenerId String
  pakket           Pakket @relation(fields: [pakketId], references: [id])
  pakketId         String
  @@id([dienstverlenerId, pakketId])
}

model DienstverlenerOrganisatie {
  dienstverlener   Dienstverlener @relation(fields: [dienstverlenerId], references: [id])
  dienstverlenerId String
  organisatie      Organisatie @relation(fields: [organisatieId], references: [id])
  organisatieId    String      @map("gemeenteId")
  @@id([dienstverlenerId, organisatieId])
  @@map("DienstverlenerOrganisatie")
}

// ─── Cloud-providers ─────────────────────────────────────────────────────────

model Cloudprovider {
  id                  String   @id @default(cuid())
  naam                String
  slug                String   @unique
  beschrijving        String?
  type                String   @default("SaaS") // IaaS, PaaS, SaaS, Hosting
  certificeringen     String?  // Comma-separated: ISO 27001, SOC 2, BIO, NEN 7510
  datacenterLocatie   String?  // Nederland, EU, Internationaal
  contactpersoon      String?
  email               String?
  telefoon            String?
  website             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  pakketten           CloudproviderPakket[]
}

model CloudproviderPakket {
  cloudprovider   Cloudprovider @relation(fields: [cloudproviderId], references: [id])
  cloudproviderId String
  pakket          Pakket @relation(fields: [pakketId], references: [id])
  pakketId        String
  @@id([cloudproviderId, pakketId])
}
